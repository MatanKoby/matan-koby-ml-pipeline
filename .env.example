# Copy to .env and fill in. .env is gitignored. Secrets must NOT be committed.

# --- Inference (Nebius Token Factory) ---
NEBIUS_API_KEY=XXX

# --- Airflow (docker-compose) ---
# On Linux, set to your host user id so mounted files aren't owned by root: `id -u`.
AIRFLOW_UID=50000
# Host docker group GID, so the Airflow worker can use the mounted Docker socket for
# DockerOperator: `getent group docker | cut -d: -f3`.
DOCKER_GID=999
# Encryption key for Airflow connections/variables: `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
FERNET_KEY=
AIRFLOW__API_AUTH__JWT_SECRET=change-me
# Airflow web UI admin (http://localhost:8080)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# --- MLflow ---
# The compose MLflow server; the DAG's summarize step logs here (http://localhost:5000 UI).
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Object Storage (S3-compatible, e.g. Nebius Object Storage) ---
# NOT used by the pipeline yet. See REPORT.md "Object Storage (S3)" for how to enable an
# upload step. Provision a bucket + static access key in Nebius, then set:
# S3_ENDPOINT_URL=https://storage.<region>.nebius.cloud:443
# S3_BUCKET=swe-bench-runs
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
